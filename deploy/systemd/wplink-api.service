[Unit]
Description=Wplink API Service
After=network.target

[Service]
Type=simple
User=wplink
Group=wplink
WorkingDirectory=/opt/wplink
EnvironmentFile=/etc/wplink/wplink.env
ExecStart=/opt/wplink/wplink-api -f /etc/wplink/app.yaml
Restart=always
RestartSec=5
LimitNOFILE=65535
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
